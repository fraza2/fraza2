# Copy this file to .env and fill in your values
# Get testnet API keys from: https://testnet.binance.vision/

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# Use testnet (recommended for testing)
TESTNET=true

# Trading pair and candle interval
SYMBOL=BTCUSDT
INTERVAL=15m

# Risk management
TRADE_QUANTITY_PERCENT=5    # Use 5% of balance per trade
MAX_OPEN_TRADES=3
STOP_LOSS_PERCENT=2.0       # Close trade if price drops 2%
TAKE_PROFIT_PERCENT=4.0     # Close trade if price rises 4%

# RSI settings
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# MACD settings
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# EMA settings
EMA_SHORT=9
EMA_LONG=21

# Bot loop interval in seconds
LOOP_INTERVAL=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
